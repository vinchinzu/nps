#!/usr/bin/env python3
"""Thin launcher: adds src/ to sys.path and invokes i990.cli.main."""
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "src"))

from i990.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
